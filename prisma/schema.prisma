generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Match {
  id                   String      @id @default(cuid())
  opponent             String
  date                 DateTime
  venue                String      @default("Cancha del Club Social")
  round                String
  isHome               Boolean     @default(true)
  status               MatchStatus @default(UPCOMING)

  earlyBirdPrice       Float
  matchDayPrice        Float
  earlyBirdDeadline    DateTime

  totalCapacity        Int         @default(300)
  soldTickets          Int         @default(0)

  tickets              Ticket[]
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  @@map("matches")
}

enum MatchStatus {
  UPCOMING
  SOLD_OUT
  FINISHED
  CANCELLED
}

model Ticket {
  id            String        @id @default(cuid())
  matchId       String
  match         Match         @relation(fields: [matchId], references: [id])

  buyerName     String
  buyerEmail    String
  buyerPhone    String

  quantity      Int           @default(1)
  unitPrice     Float
  totalAmount   Float
  isEarlyBird   Boolean       @default(false)

  mpPaymentId   String?       @unique
  mpStatus      String?       @default("pending")

  qrCode        String        @unique @default(cuid())
  pdfSent       Boolean       @default(false)

  createdAt     DateTime      @default(now())
  paidAt        DateTime?

  @@map("tickets")
}